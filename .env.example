# Keystatic CMS Configuration
# GitHub OAuth Application Settings
# Create a GitHub OAuth App at: https://github.com/settings/developers

KEYSTATIC_GITHUB_CLIENT_ID=your_github_client_id
KEYSTATIC_GITHUB_CLIENT_SECRET=your_github_client_secret

# GitHub Repository Configuration
# The repository where content will be stored
# Format: owner/repo-name
KEYSTATIC_GITHUB_REPO_OWNER=khemendra-labs
KEYSTATIC_GITHUB_REPO_NAME=portfolio

# Optional: Custom GitHub API URL for GitHub Enterprise
# KEYSTATIC_GITHUB_API_URL=https://api.github.com
